# =============================================================================
# Epidemiology AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Project Settings
# -----------------------------------------------------------------------------
PROJECT_NAME=Epidemiology AI
VERSION=1.0.0
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Security Settings (CHANGE THESE IN PRODUCTION!)
# -----------------------------------------------------------------------------
# Generate a secure secret key: openssl rand -hex 32
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://appuser:strongpassword@localhost:5432/epidemiology_ai

# -----------------------------------------------------------------------------
# External API Keys
# -----------------------------------------------------------------------------
# NOAA Weather API (https://www.ncdc.noaa.gov/cdo-web/webservices/v2)
NOAA_API_KEY=

# Google Trends (pytrends - no API key required, but rate limited)
# Social Media APIs (if using Twitter/Facebook)
TWITTER_API_KEY=
TWITTER_API_SECRET=

# -----------------------------------------------------------------------------
# Redis (for Celery task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Email Configuration (for alerts)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@epidemiology-ai.org

# -----------------------------------------------------------------------------
# Twilio (for SMS alerts)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# MLflow (for model tracking)
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=epidemiology_outbreak_prediction

# -----------------------------------------------------------------------------
# CORS Settings (for frontend)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
